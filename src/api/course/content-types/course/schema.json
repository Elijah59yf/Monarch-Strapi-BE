{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "Title": {
      "type": "string",
      "required": true
    },
    "CourseCode": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "Faculty": {
      "type": "enumeration",
      "enum": [
        "General",
        "STEM",
        "Arts",
        "Basic Medical Sciences",
        "Clinical Sciences",
        "Engineering",
        "Law",
        "Management Sciences",
        "Science",
        "Social Sciences",
        "Education",
        "Environmental Sciences",
        "Pharmacy"
      ],
      "default": "General",
      "required": true
    },
    "Department": {
      "type": "enumeration",
      "enum": [
        "General",
        "Computer Engineering",
        "Systems Engineering",
        "Mechanical Engineering",
        "Electrical and Electronics Engineering",
        "Civil Engineering",
        "Chemical Engineering",
        "Surveying and Geoinformatics",
        "Computer Science",
        "Mathematics",
        "Physics",
        "Chemistry",
        "Geosciences",
        "Cell Biology and Genetics",
        "Marine Sciences",
        "Business Administration",
        "Accounting",
        "Finance",
        "Economics",
        "Mass Communication",
        "Political Science",
        "Psychology",
        "Sociology",
        "Law",
        "Medicine and Surgery",
        "Dentistry",
        "Pharmacy",
        "Nursing",
        "Architecture",
        "Estate Management",
        "English",
        "History and Strategic Studies",
        "Philosophy",
        "Creative Arts"
      ],
      "default": "General",
      "required": true
    },
    "NormalPrice": {
      "type": "integer",
      "required": true,
      "default": 500
    },
    "LatePrice": {
      "type": "integer",
      "required": true,
      "default": 700
    },
    "IsNormalRegOpen": {
      "type": "boolean",
      "default": true
    },
    "IsLateRegOpen": {
      "type": "boolean",
      "default": false
    },
    "BatchCapacity": {
      "type": "integer",
      "default": 18
    },
    "ActiveBatches": {
      "type": "json",
      "default": []
    },
    "MoodleCourseID": {
      "type": "integer",
      "required": true
    },
    "GroupChatLink": {
      "type": "string"
    },
    "IsPasswordReleaseOpen": {
      "type": "boolean",
      "default": false
    },
    "Hidden": {
      "type": "boolean",
      "default": false
    },
    "exam_credentials": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::exam-credential.exam-credential",
      "mappedBy": "courses"
    }
  }
}
